Options -MultiViews -Indexes
DirectorySlash Off
RewriteEngine On
RewriteBase /

# SPA entry untouched
RewriteRule ^index\.html$ - [L]

# 1. Real existing file/symlink -> serve as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -l
RewriteRule ^ - [L]

# 2. cleanUrls: /path -> /path.html if the prerendered file exists
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# 3. SPA fallback
RewriteRule . /index.html [L]
